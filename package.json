{
  "name": "pdf-studio",
  "productName": "PDF Studio",
  "version": "1.0.0",
  "description": "أدوات PDF عربية — تطبيق سطح مكتب",
  "homepage": "https://github.com/abdo3342/pdf-studio",
  "author": "abdo3342",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/copy-vendor.cjs",
    "vendor": "node scripts/copy-vendor.cjs",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:linux-deb": "electron-builder --linux deb",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "3.11.174",
    "sortablejs": "1.15.7"
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.pdfstudio.desktop",
    "files": [
      "electron/**/*",
      "index.html",
      "assets/**/*",
      "concept-*.html",
      "showcase.html"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "assets/branding/app-icon-512.png",
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "maintainer": "abdo3342"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
